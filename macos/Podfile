platform :osx, '26.0'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'ephemeral', 'Flutter-Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure \"flutter pub get\" is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Flutter-Generated.xcconfig, then run \"flutter pub get\""
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_macos_podfile_setup

target 'Runner' do
  use_frameworks! :linkage => :static

  flutter_install_all_macos_pods File.dirname(File.realpath(__FILE__))
  target 'RunnerTests' do
    inherit! :search_paths
  end
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_macos_build_settings(target)
    target.build_configurations.each do |config|
      # Suppress 'has no symbols' warning from libtool for static frameworks
      config.build_settings['OTHER_LIBTOOLFLAGS'] = '$(inherited) -no_warning_for_no_symbols'
      config.build_settings['CLANG_CXX_LANGUAGE_STANDARD'] = 'c++17'
    end

    # Bundle libheif and its transitive Homebrew dependencies into Frameworks/
    # so the sandboxed macOS app can dlopen() them at runtime.
    if target.name == 'Runner'
      bundle_heif = target.new_shell_script_build_phase('Bundle libheif dylibs')
      bundle_heif.shell_script = <<~'SHELL'
        set -e
        BREW="/opt/homebrew"
        FRAMEWORKS="${BUILT_PRODUCTS_DIR}/${FRAMEWORKS_FOLDER_PATH}"
        mkdir -p "$FRAMEWORKS"

        # Ordered list: deps first so install_name_tool rewrites are consistent.
        DYLIBS=(
          "${BREW}/opt/libvmaf/lib/libvmaf.3.dylib"
          "${BREW}/opt/webp/lib/libsharpyuv.0.dylib"
          "${BREW}/opt/libde265/lib/libde265.0.dylib"
          "${BREW}/opt/x265/lib/libx265.215.dylib"
          "${BREW}/opt/aom/lib/libaom.3.dylib"
          "${BREW}/opt/libheif/lib/libheif.1.dylib"
        )

        for SRC in "${DYLIBS[@]}"; do
          [ -f "$SRC" ] || { echo "warning: $SRC not found — skipping"; continue; }
          BASENAME=$(basename "$SRC")
          DEST="$FRAMEWORKS/$BASENAME"
          cp -f "$SRC" "$DEST"
          chmod u+w "$DEST"

          # Rewrite this dylib's own install name to @rpath-relative
          install_name_tool -id "@rpath/$BASENAME" "$DEST"

          # Rewrite references to all of its Homebrew siblings
          for SRC2 in "${DYLIBS[@]}"; do
            BASENAME2=$(basename "$SRC2")
            # Replace any absolute Homebrew path pointing to this dep
            OLD1="${BREW}/opt/libvmaf/lib/$BASENAME2"
            OLD2="${BREW}/opt/webp/lib/$BASENAME2"
            OLD3="${BREW}/opt/libde265/lib/$BASENAME2"
            OLD4="${BREW}/opt/x265/lib/$BASENAME2"
            OLD5="${BREW}/opt/aom/lib/$BASENAME2"
            OLD6="${BREW}/opt/libheif/lib/$BASENAME2"
            NEW="@rpath/$BASENAME2"
            for OLD in "$OLD1" "$OLD2" "$OLD3" "$OLD4" "$OLD5" "$OLD6"; do
              install_name_tool -change "$OLD" "$NEW" "$DEST" 2>/dev/null || true
            done
          done

          echo "Bundled: $BASENAME"
        done
      SHELL
    end

    # The ort crate's ONNX Runtime build includes onnx-ml.pb.cc.o twice in the
    # static archive (from onnxruntime_static + onnx_proto compilation units).
    # When Runner force-loads the .a, the linker fails on the 756 duplicate symbols.
    # Fix: after Cargokit builds librust_lib_rackery.a, deduplicate it by extracting
    # all objects (ar -x overwrites duplicates → natural dedup) and re-archiving.
    if target.name == 'rust_lib_rackery'
      dedup = target.new_shell_script_build_phase('Deduplicate Rust Static Library')
      dedup.shell_script = <<~'SHELL'
        set -e
        RUST_LIB="${BUILT_PRODUCTS_DIR}/librust_lib_rackery.a"
        [ -f "$RUST_LIB" ] || exit 0

        TEMP_DIR=$(mktemp -d)
        ARCHES=$(lipo -archs "$RUST_LIB" 2>/dev/null || echo "")

        if [ -z "$ARCHES" ]; then
          rm -rf "$TEMP_DIR"; exit 0
        fi

        DEDUPED_SLICES=""
        for ARCH in $ARCHES; do
          SLICE_DIR="$TEMP_DIR/$ARCH"
          mkdir -p "$SLICE_DIR"
          lipo "$RUST_LIB" -thin "$ARCH" -output "$SLICE_DIR/thin.a"
          OBJ_DIR="$SLICE_DIR/objs"
          mkdir -p "$OBJ_DIR"

          # List all members in order, then extract only the FIRST occurrence of each name.
          # ar -t lists members; we track seen names and skip later dupes.
          # ar -x with a member name extracts just that member (first match).
          ar -t "$SLICE_DIR/thin.a" | awk '!seen[$0]++' | while read -r MEMBER; do
            [ -z "$MEMBER" ] && continue
            (cd "$OBJ_DIR" && ar -x "$SLICE_DIR/thin.a" "$MEMBER" 2>/dev/null || true)
          done

          OBJ_COUNT=$(find "$OBJ_DIR" -name "*.o" | wc -l | tr -d ' ')
          if [ "$OBJ_COUNT" -gt 0 ]; then
            (cd "$OBJ_DIR" && find . -name "*.o" -print0 | xargs -0 ar -cr dedup.a)
            ranlib "$OBJ_DIR/dedup.a" 2>/dev/null || true
            DEDUPED_SLICES="$DEDUPED_SLICES $OBJ_DIR/dedup.a"
            echo "[$ARCH] Deduplicated: $OBJ_COUNT unique objects"
          fi
        done

        if [ -n "$DEDUPED_SLICES" ]; then
          lipo -create $DEDUPED_SLICES -output "$RUST_LIB"
          echo "Rebuilt fat archive: $RUST_LIB"
        fi
        rm -rf "$TEMP_DIR"
      SHELL
    end
  end
end
